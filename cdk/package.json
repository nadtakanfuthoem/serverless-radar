{
  "name": "serverless-radar-cdk",
  "version": "1.0.0",
  "description": "CDK infrastructure for Serverless Radar",
  "main": "bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "deploy": "source ../.env && cdk deploy --profile $AWS_PROFILE",
    "destroy": "source ../.env && cdk destroy --profile $AWS_PROFILE",
    "diff": "source ../.env && cdk diff --profile $AWS_PROFILE",
    "synth": "source ../.env && cdk synth --profile $AWS_PROFILE"
  },
  "devDependencies": {
    "aws-cdk": "^2.200.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.200.0",
    "constructs": "^10.0.0",
    "dotenv": "^16.4.0"
  }
}
